{
  "name": "@triminds/ui-core",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/triminds-ui.cjs.js",
  "module": "./dist/triminds-ui.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/triminds-ui.es.js",
      "require": "./dist/triminds-ui.cjs.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "react": "^18.3.0",
